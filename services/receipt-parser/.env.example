# OpenTelemetry
OTEL_SERVICE_NAME=receipt-parser

# Toggle local upload test endpoint
# true면 /api/tests/local-upload-parse 엔드포인트가 열립니다.
ReceiptParser__EnableLocalUploadTestEndpoint=true

# Document Intelligence
ReceiptParser__DocumentIntelligenceEndpoint=https://<your-doc-intelligence-name>.cognitiveservices.azure.com/
ReceiptParser__DocumentIntelligenceApiKey=<your-doc-intelligence-api-key>
ReceiptParser__ModelId=prebuilt-receipt

# Cosmos DB (IAM / Managed Identity or Azure CLI 로그인 기준)
ReceiptParser__CosmosAccountEndpoint=https://<your-cosmos-account>.documents.azure.com:443/
ReceiptParser__CosmosDatabaseId=settle-up
ReceiptParser__CosmosContainerId=receipts

# Downstream Event Grid (선택)
ReceiptParser__DownstreamEventGridTopicEndpoint=
ReceiptParser__DownstreamEventGridTopicKey=
ReceiptParser__DownstreamEventType=SettleUp.ReceiptParsed
